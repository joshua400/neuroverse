# =============================================
# India-First MCP — Environment Configuration
# =============================================
# Copy this file to .env and fill in your values.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/india_mcp

# --- AI Model API Keys ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
SARVAM_API_KEY=...

# --- Ollama (Local) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Safety ---
SAFETY_STRICT_MODE=true

# --- Server ---
MCP_TRANSPORT=stdio
# MCP_TRANSPORT=streamable_http
# MCP_PORT=8000
